{
  "name": "my-tiny-events",
  "version": "1.0.0",
  "description": "A lightweight, dependency-free event emitter system for JavaScript and TypeScript, inspired by Node.js EventEmitter with support for multi-event handling and listener management.",
  "scripts": {
    "test": "npm run test:mjs && npm run test:cjs && npm run test:js",
    "test:js": "node -r @babel/register test/index.js",
    "test:cjs": "node test/index.cjs",
    "test:mjs": "node test/index.mjs",
    "test:mjs:tiny": "node test/index.mjs",
    "test:mjs:cert": "node test/index.mjs",
    "test:mjs:chain": "node test/index.mjs",
    "fix:prettier": "npm run fix:prettier:src && npm run fix:prettier:test && npm run fix:prettier:rollup.config && npm run fix:prettier:webpack.config",
    "fix:prettier:src": "prettier --write ./src/*",
    "fix:prettier:test": "prettier --write ./test/*",
    "fix:prettier:rollup.config": "prettier --write ./rollup.config.mjs",
    "fix:prettier:webpack.config": "prettier --write ./webpack.config.mjs",
    "auto-build": "npm run build",
    "build": "tsc -p tsconfig.json && rollup -c && webpack --mode production",
    "build-clean": "npm run clean && npm run build",
    "build-dist": "npm run build",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "ethereum": "jasmindreasond.x",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tiny-Essentials/My-Tiny-Events.git"
  },
  "keywords": [
    "my-tiny-events",
    "event-emitter",
    "emitter",
    "events",
    "observer",
    "lightweight",
    "dependency-free",
    "tiny",
    "node-events",
    "browser-events",
    "javascript",
    "event-driven"
  ],
  "author": "Yasmin Seidel (Jasmin Dreasond)",
  "license": "LGPL-3.0-only",
  "bugs": {
    "url": "https://github.com/Tiny-Essentials/My-Tiny-Events/issues"
  },
  "homepage": "https://github.com/Tiny-Essentials/My-Tiny-Events#readme",
  "devDependencies": {
    "@babel/cli": "^8.0.1",
    "@babel/core": "^8.0.1",
    "@babel/node": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/register": "^8.0.1",
    "@matrix-org/olm": "^3.2.15",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "babel-preset-es2015": "^6.24.1",
    "lodash": "^4.17.21",
    "node-polyfill-webpack-plugin": "^4.1.0",
    "prettier": "^3.9.4",
    "rollup": "^4.62.2",
    "rollup-preserve-directives": "^1.1.3",
    "tslib": "^2.8.1",
    "type-fest": "^5.8.0",
    "typescript": "^7.0.2",
    "webpack": "^5.99.6",
    "webpack-cli": "^7.2.1"
  }
}
